def quem_passou_de_ano(notas_da_turma):
    aprovados = []

    for nota in notas_da_turma:
        if nota >= 7.0:
            aprovados.append(nota)

    return aprovados


notas_dos_alunos = [8.5, 4.2, 7.0, 9.1, 5.5]

resultado_final = quem_passou_de_ano(notas_dos_alunos)

